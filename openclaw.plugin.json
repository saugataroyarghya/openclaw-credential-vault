{
  "id": "credential-vault",
  "name": "Credential Vault",
  "description": "Generic per-user credential vault with OAuth, API key management, and auth gating for OpenClaw agents.",
  "version": "0.1.0",
  "skills": ["skills/vault-admin"],
  "configSchema": {
    "type": "object",
    "properties": {
      "providers": {
        "type": "object",
        "description": "OAuth and API key provider definitions.",
        "additionalProperties": {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "enum": ["oauth2", "api_key"],
              "description": "Authentication type."
            },
            "authUrl": {
              "type": "string",
              "description": "OAuth2 authorization endpoint URL."
            },
            "tokenUrl": {
              "type": "string",
              "description": "OAuth2 token exchange endpoint URL."
            },
            "revokeUrl": {
              "type": "string",
              "description": "OAuth2 token revocation endpoint URL."
            },
            "scopes": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Default OAuth scopes to request."
            },
            "maxScopes": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Maximum scopes any user can request."
            },
            "minScopes": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Minimum scopes required for the provider to be useful."
            },
            "clientId": {
              "description": "OAuth client ID — string or { env: 'VAR_NAME' }."
            },
            "clientSecret": {
              "description": "OAuth client secret — string or { env: 'VAR_NAME' }."
            },
            "pkce": {
              "type": "boolean",
              "description": "Enable PKCE for this provider."
            },
            "inject": {
              "type": "string",
              "enum": ["bearer", "header", "query"],
              "description": "How to inject the credential into requests."
            },
            "headerName": {
              "type": "string",
              "description": "Custom header name for injection."
            },
            "headerPrefix": {
              "type": "string",
              "description": "Custom header value prefix."
            },
            "queryParamName": {
              "type": "string",
              "description": "Query parameter name for query injection."
            }
          },
          "required": ["type"]
        }
      },
      "mcpServers": {
        "type": "object",
        "description": "MCP servers to bridge — tools are auto-discovered and registered.",
        "additionalProperties": {
          "type": "object",
          "properties": {
            "url": {
              "type": "string",
              "description": "MCP server URL."
            },
            "transport": {
              "type": "string",
              "enum": ["streamable-http", "sse"],
              "description": "Transport protocol."
            },
            "auth": {
              "type": "object",
              "description": "Credential injection config for this MCP server.",
              "properties": {
                "provider": {
                  "type": "string",
                  "description": "Which provider's credential to inject."
                },
                "inject": {
                  "type": "string",
                  "enum": ["bearer", "header", "query"]
                },
                "headerName": { "type": "string" },
                "headerPrefix": { "type": "string" }
              },
              "required": ["provider"]
            },
            "toolPrefix": {
              "type": "string",
              "description": "Prefix for registered tool names. Defaults to server key."
            }
          },
          "required": ["url"]
        }
      },
      "toolProviderMap": {
        "type": "object",
        "description": "Maps tool name patterns to required providers. Supports wildcards (e.g., 'github_*').",
        "additionalProperties": {}
      },
      "userPolicies": {
        "type": "object",
        "description": "Per-user scope restrictions. Keyed by channel user ID.",
        "additionalProperties": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "scopes": {
                "type": "array",
                "items": { "type": "string" }
              },
              "allowWrite": { "type": "boolean" }
            }
          }
        }
      },
      "channelPolicies": {
        "type": "object",
        "description": "Per-channel access control. Keys are conversation channel IDs (e.g., C_ENGINEERING), 'DM', or 'default'. Each entry defines which providers and tools are available.",
        "additionalProperties": {
          "type": "object",
          "properties": {
            "providers": {
              "type": "object",
              "description": "Allowed providers and their tool patterns.",
              "additionalProperties": {
                "type": "object",
                "properties": {
                  "tools": {
                    "type": "array",
                    "items": { "type": "string" },
                    "description": "Tool name patterns (relative to provider prefix). Use '*' for all, 'list_*' for prefix match."
                  }
                },
                "required": ["tools"]
              }
            },
            "userOverrides": {
              "type": "object",
              "description": "Per-user overrides within this channel. Replaces (not merges) the channel defaults.",
              "additionalProperties": {
                "type": "object",
                "properties": {
                  "providers": {
                    "type": "object",
                    "additionalProperties": {
                      "type": "object",
                      "properties": {
                        "tools": {
                          "type": "array",
                          "items": { "type": "string" }
                        }
                      },
                      "required": ["tools"]
                    }
                  }
                },
                "required": ["providers"]
              }
            }
          },
          "required": ["providers"]
        }
      },
      "callbackBaseUrl": {
        "type": "string",
        "description": "Base URL for OAuth callbacks (e.g., https://your-domain.com). Required for OAuth providers."
      },
      "rateLimitPerUserPerMinute": {
        "type": "number",
        "description": "Max tool calls per user per provider per minute. Default: 60."
      }
    },
    "required": ["providers"]
  },
  "uiHints": {
    "providers.*.clientSecret": { "sensitive": true },
    "providers.*.clientId": { "sensitive": true }
  }
}
